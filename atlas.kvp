App.WindowsCommandLineArgs=
App.CommandLineArgs=Ocean?ServerX={{ServerX}}?ServerY={{ServerY}}?AltSaveDirectoryName={{SaveDir}}?ServerAdminPassword={{AdminPassword}}?MaxPlayers={{$MaxUsers}}?QueryPort={{$QueryPort}}?Port={{$GamePort}}?SeamlessIP={{SeamlessIP}}?RCONEnabled=True?RCONPort={{$RCONPort}} -log -server -NoBattlEye {{CustomArgs}}
